# Configuración de Producción
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion-abc123xyz
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com

# Base de Datos (usar DATABASE_URL para Render/Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Alternativa local con SQLite:
# DATABASE_URL=sqlite:///db.sqlite3

# CORS (reemplazar con dominio del frontend)
CORS_ALLOWED_ORIGINS=https://tu-frontend.com,https://www.tu-frontend.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# API Externa (índices económicos)
ARGLY_API_BASE=https://api.argly.com.ar/api
RAPIDAPI_KEY=

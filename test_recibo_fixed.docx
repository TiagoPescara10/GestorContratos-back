                <ol start='20' class="post-context" id="post123155389684608">
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    if not isinstance(numero, (int, float, Decimal)):</pre></li>
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>        raise ValueError(&quot;El número debe ser de tipo int, float o Decimal&quot;)</pre></li>
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    </pre></li>
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    # Convertir Decimal a float para num2words</pre></li>
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    if isinstance(numero, Decimal):</pre></li>
                  
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>        numero = float(numero)</pre></li>
                  

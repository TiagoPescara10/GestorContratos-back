                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    Example:</pre></li>
                
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>        &gt;&gt;&gt; convertir_a_letras(578496)</pre></li>
                
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>        &#x27;QUINIENTOS SETENTA Y OCHO MIL CUATROCIENTOS NOVENTA Y SEIS&#x27;</pre></li>
                
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    &quot;&quot;&quot;</pre></li>
                
                  <li onclick="toggle('pre123155389684608', 'post123155389684608')"><pre>    from decimal import Decimal</pre></li>
                
